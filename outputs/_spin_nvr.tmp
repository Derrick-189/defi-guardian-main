never safety_no_overflow {    /* !([] (((balance>=0)) && ((balance<=1000000)))) */
T0_init:
	do
	:: atomic { (! ((((balance>=0)) && ((balance<=1000000))))) -> assert(!(! ((((balance>=0)) && ((balance<=1000000)))))) }
	:: (1) -> goto T0_init
	od;
accept_all:
	skip
}
never liveness_progress {    /* !(<> ((state==1))) */
accept_init:
T0_init:
	do
	:: (! (((state==1)))) -> goto T0_init
	od;
}
never invariant_balance {    /* !([] ((balance>=0))) */
T0_init:
	do
	:: atomic { (! (((balance>=0)))) -> assert(!(! (((balance>=0))))) }
	:: (1) -> goto T0_init
	od;
accept_all:
	skip
}
