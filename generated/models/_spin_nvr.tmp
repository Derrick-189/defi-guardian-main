never safety_no_overflow {    /* !([] (((amount>=0)) && ((amount<=1000000)))) */
T0_init:
	do
	:: atomic { (! ((((amount>=0)) && ((amount<=1000000))))) -> assert(!(! ((((amount>=0)) && ((amount<=1000000)))))) }
	:: (1) -> goto T0_init
	od;
accept_all:
	skip
}
never safety_reentrancy {    /* !([] (! ((lock) && ((amount>100))))) */
T0_init:
	do
	:: atomic { (! ((! ((lock) && ((amount>100)))))) -> assert(!(! ((! ((lock) && ((amount>100))))))) }
	:: (1) -> goto T0_init
	od;
accept_all:
	skip
}
never liveness_progress {    /* !(<> ((state==2))) */
accept_init:
T0_init:
	do
	:: (! (((state==2)))) -> goto T0_init
	od;
}
never invariant_collateral {    /* !([] ((user_collateral>=user_debt))) */
T0_init:
	do
	:: atomic { (! (((user_collateral>=user_debt)))) -> assert(!(! (((user_collateral>=user_debt))))) }
	:: (1) -> goto T0_init
