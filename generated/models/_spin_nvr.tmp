never response_price_drop {    /* !([] ((! ((price_eth<50))) || (<> ((health_factor<150))))) */
T0_init:
	do
	:: (! ((! ((price_eth<50)))) && ! (((health_factor<150)))) -> goto accept_S4
	:: (1) -> goto T0_init
	od;
accept_S4:
	do
	:: (! (((health_factor<150)))) -> goto accept_S4
	od;
}
